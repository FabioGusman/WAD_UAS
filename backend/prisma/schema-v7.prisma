// prisma/schema-v7.prisma
// Versi Prisma 7
//
// PERBEDAAN dari schema.prisma (Prisma 5):
//   - generator: output WAJIB ditentukan, client tidak lagi di node_modules
//   - datasource: url DIHAPUS dari sini, dipindah ke prisma.config.js
//   - Import di kode: require('./generated/prisma'), bukan '@prisma/client'

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"   // ← WAJIB di Prisma 7
}

datasource db {
  provider = "mysql"
  // ↑ url TIDAK ADA di sini — sudah dipindah ke prisma.config.js
}

// ── Tabel 1: Category ────────────────────────────────────────
model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())

  products  Product[]
}

// ── Tabel 2: Product ─────────────────────────────────────────
model Product {
  id          Int      @id @default(autoincrement())
  name        String
  price       Float
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
}
